# Byte-compiled / optimized
**/__pycache__/
*.py[codz]
*$py.class
*.so

# Claude code
CLAUDE.md

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Environments
.env
.venv
venv/
.envrc
.direnv/

# IDEs and editors
.idea/
.vscode/
.claude/settings.local.json
*.swp
*.swo
*~

# Type checkers / linters / test caches
.mypy_cache/
.ruff_cache/
.pytype/
.pytest_cache/

# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml

# Profiling
*.prof
prof/
*.lprof

# JAX / XLA caches and dumps
.jax_cache/
jax_cache/
xla_dump/
*.xla_pb

# Jupyter
.ipynb_checkpoints/

# macOS
.DS_Store

# Scratch / temp files
*.tmp
*.bak
*.orig
*.rej

# VULCAN simulation outputs (binary pickle, ~10+ MB each)
*.vul

# VULCAN per-run config snapshot (Output.save_out copies vulcan_cfg.py here)
output/cfg_*.txt

# Live-UI artifacts (movies / frames written next to outputs)
output/movie_*/
output/*_movie/
output/*.mp4
output/*.gif

# FastChem runtime-generated files (regenerated each run by ini_abun._run_fastchem)
fastchem_vulcan/.fastchem_lock
fastchem_vulcan/input/parameters.dat
fastchem_vulcan/input/element_abundances_vulcan.dat
fastchem_vulcan/input/vulcan_TP/vulcan_TP.dat
fastchem_vulcan/output/monitor_output.dat
fastchem_vulcan/output/chem_species.dat
fastchem_vulcan/output/vulcan_EQ.dat

# Large scientific data formats (typically big binary arrays/tables)
*.h5
*.hdf5
*.nc
*.npy
*.npz
*.parquet
*.pkl
*.pickle
*.feather

# ML model checkpoints
*.pt
*.pt2
*.pth
*.ckpt
*.onnx

# Archives
*.zip
*.tar
*.tar.gz
*.tgz

# Logs
*.log
logs/

# Generated plots (the plot/ dir is for generated figures)
plot/*.png
plot/*.pdf
plot/*.jpg
plot/*.jpeg
plot/*.svg
